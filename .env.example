# Domain Configuration
DOMAIN=YOUR_DOMAIN
ACME_EMAIL=your-email@example.com

# Server Configuration
SERVER_IP=YOUR_SERVER_IP

# Headscale Configuration (auto-generated by setup.sh)
HEADSCALE_API_KEY=hs_auto_generated_on_setup
